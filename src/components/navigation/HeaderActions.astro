---
import SocialLinks from "./SocialLinks.astro"
import ThemeToggle from "./ThemeToggle.astro"
import MobileNav from "./MobileNav.astro"
import Button from "../ui/Button.astro"
import { site } from "../../data/site"
---

<div class="header-actions">
  <div class="header-actions__desktop">
    <SocialLinks />
    <ThemeToggle />
    <Button href={site.resume} class="header-actions__resume">
      Download Resume
      <svg
        width="15"
        height="15"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <path d="M12 3v12"></path>
        <path d="m7 10 5 5 5-5"></path>
        <path d="M5 21h14"></path>
      </svg>
    </Button>
  </div>

  <div class="header-actions__mobile">
    <ThemeToggle />
    <MobileNav />
  </div>
</div>

<style>
  .header-actions {
    display: flex;
    align-items: center;
  }

  .header-actions__desktop {
    display: none;
    align-items: center;
    gap: 0.375rem;
  }

  .header-actions__mobile {
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  .header-actions__resume {
    margin-left: var(--space-2);
    padding-inline: 0.9rem;
    font-size: 0.8125rem;
    font-weight: 600;
  }

  @media (min-width: 900px) {
    .header-actions__desktop {
      display: flex;
    }

    .header-actions__mobile {
      display: none;
    }
  }
</style>
