---
interface Props {
  size?: number
  class?: string
}

const { size = 36, class: className } = Astro.props
---

<svg
  class:list={["brand-mark", className]}
  width={size}
  height={size}
  viewBox="0 0 84 64"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  aria-hidden="true"
  focusable="false"
>
  <!-- Stylized M (3 segments) -->
  <path
    class="brand-mark__m"
    d="M10 58V6L34 42L52 6"
    stroke-width="11"
    stroke-linecap="butt"
    stroke-linejoin="miter"
  ></path>
  <!-- Blue K as left-pointing chevron -->
  <path
    class="brand-mark__k"
    d="M78 6L56 32L78 58"
    stroke-width="11"
    stroke-linecap="butt"
    stroke-linejoin="miter"
  ></path>
</svg>

<style>
  .brand-mark {
    display: block;
    flex-shrink: 0;
    overflow: visible;
  }

  .brand-mark__m {
    fill: none;
    stroke: currentColor;
    color: var(--color-text);
  }

  .brand-mark__k {
    fill: none;
    stroke: var(--color-primary);
  }
</style>
