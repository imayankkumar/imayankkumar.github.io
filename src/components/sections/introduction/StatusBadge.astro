---
export interface Props {
  label: string
  description?: string
  variant?: "role" | "light" | "dark"
  icon?: "patent" | "pulse" | "globe"
  class?: string
}

const {
  label,
  description,
  variant = "role",
  icon,
  class: className,
} = Astro.props
---

<span
  class:list={[
    "status-badge",
    `status-badge--${variant}`,
    description && "status-badge--stacked",
    className,
  ]}
>
  {
    icon === "patent" && (
      <svg
        class="status-badge__icon"
        width="16"
        height="16"
        viewBox="0 0 24 24"
        fill="none"
        aria-hidden="true"
      >
        <circle cx="12" cy="9" r="5.25" stroke="currentColor" stroke-width="1.75" />
        <path
          d="M9.5 13.5 8 21l4-2.25L16 21l-1.5-7.5"
          stroke="currentColor"
          stroke-width="1.75"
          stroke-linecap="round"
          stroke-linejoin="round"
        />
        <path
          d="M10.25 8.25h3.5M12 7v3"
          stroke="currentColor"
          stroke-width="1.75"
          stroke-linecap="round"
        />
      </svg>
    )
  }
  {
    icon === "pulse" && (
      <svg
        class="status-badge__icon"
        width="16"
        height="16"
        viewBox="0 0 24 24"
        fill="none"
        aria-hidden="true"
      >
        <path
          d="M3 12h3.5l2-5 3.5 10 2.5-5H21"
          stroke="currentColor"
          stroke-width="1.75"
          stroke-linecap="round"
          stroke-linejoin="round"
        />
      </svg>
    )
  }
  {
    icon === "globe" && (
      <svg
        class="status-badge__icon"
        width="18"
        height="18"
        viewBox="0 0 24 24"
        fill="none"
        aria-hidden="true"
      >
        <circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.75" />
        <path
          d="M3 12h18M12 3c2.5 2.7 3.75 5.7 3.75 9S14.5 18.3 12 21c-2.5-2.7-3.75-5.7-3.75-9S9.5 5.7 12 3Z"
          stroke="currentColor"
          stroke-width="1.75"
          stroke-linecap="round"
          stroke-linejoin="round"
        />
      </svg>
    )
  }
  <span class="status-badge__text">
    <span class="status-badge__label">{label}</span>
    {description && <span class="status-badge__description">{description}</span>}
  </span>
</span>

<style>
  .status-badge {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    width: fit-content;
    padding: var(--space-1) var(--space-3);
    border: 1px solid transparent;
    border-radius: 999px;
    font-size: var(--text-sm);
    font-weight: 500;
    line-height: 1.4;
  }

  .status-badge:not(.status-badge--stacked) {
    white-space: nowrap;
  }

  .status-badge--stacked {
    align-items: center;
    gap: var(--space-3);
    padding: 0.55rem 0.9rem;
    border-radius: var(--radius-md);
  }

  .status-badge__icon {
    flex-shrink: 0;
  }

  .status-badge__text {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.15rem;
    min-width: 0;
  }

  .status-badge__label {
    display: block;
    font-weight: 600;
    line-height: 1.25;
  }

  .status-badge__description {
    display: block;
    font-size: 0.75rem;
    font-weight: 400;
    line-height: 1.3;
    color: #9ca3af;
    white-space: nowrap;
  }

  .status-badge--role {
    border-color: color-mix(in srgb, var(--color-primary) 35%, transparent);
    background: color-mix(in srgb, var(--color-primary) 10%, transparent);
    color: var(--color-primary);
  }

  .status-badge--light {
    border-color: #e5e7eb;
    background: #ffffff;
    color: #111827;
    box-shadow: var(--shadow-md);
  }

  .status-badge--light .status-badge__icon {
    color: #d4a017;
  }

  .status-badge--dark {
    border-color: transparent;
    background: #111827;
    color: #ffffff;
    box-shadow: var(--shadow-md);
  }

  .status-badge--dark .status-badge__icon {
    color: #3b82f6;
  }
</style>
