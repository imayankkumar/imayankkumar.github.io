---
export interface Props {
  id?: string
  as?: "section" | "div"
  class?: string
  "aria-labelledby"?: string
  "aria-label"?: string
}

const {
  id,
  as: Tag = "section",
  class: className,
  "aria-labelledby": ariaLabelledby,
  "aria-label": ariaLabel,
} = Astro.props
---

<Tag
  id={id}
  class:list={["section", className]}
  aria-labelledby={ariaLabelledby}
  aria-label={ariaLabel}
>
  <slot />
</Tag>

<style>
  .section {
    padding-block: var(--space-16);
  }
</style>
